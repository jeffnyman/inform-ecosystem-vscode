{
  "comments": {
    "blockComment": [
      "[", "]"
    ],
  },
  "brackets": [
    [
      "[", "]"
    ],
    [
      "(", ")"
    ],
    [
      "{", "}"
    ],
    [
      "(+", "+)"
    ],
    [
      "(-", "-)"
    ]
  ],
  "autoClosingPairs": [
    [
      "[", "]"
    ],
    [
      "(", ")"
    ],
    [
      "{", "}"
    ],
    [
      "(+", "+)"
    ],
    [
      "(-", "-)"
    ],
    [
      "\"", "\""
    ],
  ],
  "folding": {
    "markers": {
      "start": "^\\s*\\[#?(begin)\\b",
      "end": "^\\s*\\[#?end\\b"
    }
  },
  "indentationRules": {
    "increaseIndentPattern": "^.*:$",
    "decreaseIndentPattern": "^\\s*[].*$"
  },
  "onEnterRules": [
    {
      "beforeText": "^\\s*$",
      "action": { "indent": "outdent" }
    }
  ]
}
